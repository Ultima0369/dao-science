# Force LF line endings for text files across platforms
* text=auto
*.py text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.tex text eol=lf
*.txt text eol=lf
*.json text eol=lf
*.js text eol=lf
*.css text eol=lf

# Treat generated image/PDF/binary assets as binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.svg binary
*.pdf binary
*.zip binary
*.tar.gz binary
